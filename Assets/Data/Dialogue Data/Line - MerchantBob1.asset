  dialogue_group_name: Merchant Bob
  speaker: {fileID: 11400000, guid: 9376e887342cc4ed18c9a6c40125a386, type: 2}
  text_line:
  - "Make it quick. Time\u2019s coin, and I\u2019m running short on both."
  - "Well, look at that\u2026 a fresh face. Try not to die too fast, bad for business."
  - "Joe\u2019s taken my tools again\u2026 one day I\u2019ll bury him for it."
  - "You break it, you buy it. I break it\u2026 well, that\u2019s just how things
    go."
